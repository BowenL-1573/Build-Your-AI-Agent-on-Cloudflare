sk_id || crypto.randomUUID());\n    }\n  }\n\n  webSocketClose(ws: WebSocket) {\n    this.sessions.delete(ws);\n  }\n\n  private send(ws: WebSocket, type: string, payload: any) {\n    ws.send(JSON.stringify({ type, ...payload }));\n  }\n\n  private async runAgent(ws: WebSocket, userMessage: string, taskId: string) {\n    // Load or init conversation history\n    const messages: ChatMessage[] = (await this.ctx.storage.get(`task:${taskId}:messages`)) || [\n      { role: \"system\", content: SYSTEM_PROMPT },\n    ];\n    const steps: StepRecord[] = (await this.ctx.storage.get(`task:${taskId}:steps`)) || [];\n\n    messages.push({ role: \"user\", content: userMessage });\n\n    this.send(ws, \"status\", { message: \"Thinking...\" });\n\n    const MAX_STEPS = 10;\n\n    for (let i = 0; i < MAX_STEPS; i++) {\n      // Call LLM via AI Gateway\n      const llmResponse = await this.callLLM(messages);\n\n      const choice = llmResponse.choices?.[0]?.message;\n      if (!choice) {\n        this.send(ws, \"error\", { message: \"LLM returned empty response\" });\n        return;\n      }\n\n      // If LLM wants to call a tool\n      if (choice.tool_calls && choice.tool_calls.length > 0) {\n        messages.push({\n          role: \"assistant\",\n          content: choice.content,\n          tool_calls: choice.tool_calls,\n        });\n\n        for (const call of choice.tool_calls) {\n          const fn = call.function;\n          this.send(ws, \"action\", { tool: fn.name, args: JSON.parse(fn.arguments) });\n\n          const result = await this.executeTool(fn.name, JSON.parse(fn.arguments), taskId);\n\n          // Record step in manifest\n          const step: StepRecord = {\n            index: steps.length,\n            action: fn.name,\n            input: JSON.parse(fn.arguments),\n            output: { text: result.text?.substring(0, 500) },\n            screenshot_url: result.screenshot_url,\n          };\n          steps.push(step);\n\n          // Send screenshot to fr