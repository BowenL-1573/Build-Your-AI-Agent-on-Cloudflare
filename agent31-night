                  "description": "URL of the AWS documentation page to read",
                  "title": "Url",
                  "type": "string"
                },
                "max_length": {
                  "exclusiveMinimum": 0,
                  "exclusiveMaximum": 1000000,
                  "description": "Maximum number of characters to return.",
                  "title": "Max Length",
                  "type": "integer",
                  "default": 5000
                },
                "start_index": {
                  "title": "Start Index",
                  "type": "integer",
