                    "Text": "=== Operation 1 Result (Text) ===\nimport { useState, useEffect, useRef } from 'react';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Textarea } from '@/components/ui/textarea';\nimport {\n  Zap,\n  Plus,\n  LogOut,\n  Play,\n  CheckCircle,\n  Clock,\n  AlertCircle,\n  Terminal,\n  Globe,\n  X,\n  Send,\n  Loader2,\n} from 'lucide-react';\nimport { Link, useNavigate } from 'react-router-dom';\nimport gsap from 'gsap';\nimport { WS_BASE } from '@/lib/api';\n\n// Types\ninterface Task {\n  id: string;\n  name: string;\n  description: string;\n  status: 'running' | 'completed' | 'paused' | 'failed';\n  progress: number;\n  createdAt: string;\n  logs: string[];\n  screenshots: string[];\n  ws?: WebSocket;\n}\n\n// Parse username from token\nfunction getUsername(): string {\n  try {\n    const token = localStorage.getItem('token');\n    if (!token) return 'User';\n    const [, username] = atob(token).split(':');\n    return username || 'User';\n  } catch {\n    return 'User';\n  }\n}\n\n// Sidebar Component\nconst Sidebar = ({ username }: { username: string }) => {\n  return (\n    <div className=\"w-64 h-screen glass-strong border-r border-white/5 flex flex-col fixed left-0 top-0\">\n      {/* Logo */}\n      <div className=\"p-6 border-b border-white/5\">\n        <Link to=\"/\" className=\"flex items-center gap-3\">\n          <div className=\"w-10 h-10 rounded-xl bg-gradient-to-br from-purple-600 to-pink-600 flex items-center justify-center\">\n            <Zap className=\"w-5 h-5 text-white\" />\n          </div>\n          <span className=\"text-xl font-bold text-white\">Agents</span>\n        </Link>\n      </div>\n\n      {/* Menu */}\n      <nav className=\"flex-1 p-4 space-y-2\">\n        <div className=\"w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-purple-600/20 text-purple-400 border border-purple-500/30\">\n          <Terminal className=\"w-5 h-5\" />\n          <span>任务中心</span>\n        </div>\n      </nav>\n\n      {/* User */}\n      <div className=\"p-4 border-t border-white/5\">\n        <div className=\"flex items-center gap-3 p-3 rounded-xl bg-white/5\">\n          <div className=\"w-10 h-10 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-semibold\">\n            {username.charAt(0).toUpperCase()}\n          </div>\n          <div className=\"flex-1 min-w-0\">\n            <div className=\"text-white font-medium truncate\">{username}</div>\n          </div>\n          <Link to=\"/\">\n            <LogOut className=\"w-5 h-5 text-gray-400 hover:text-white cursor-pointer\" />\n          </Link>\n        </div>\n      </div>\n    </div>\n  );\n};\n\n// New Task Modal\nconst NewTaskModal = ({\n  isOpen,\n  onClose,\n  onCreate,\n}: {\n  isOpen: boolean;\n  onClose: () => void;\n  onCreate: (task: Partial<Task>) => void;\n}) => {\n  const [taskName, setTaskName] = useState('');\n  const [taskDesc, setTaskDesc] = useState('');\n  const modalRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    if (isOpen && modalRef.current) {\n      gsap.fromTo(\n        modalRef.current,\n        { opacity: 0, scale: 0.95 },\n        { opacity: 1, scale: 1, duration: 0.3, ease: 'expo.out' }\n      );\n    }\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!taskName) return;\n\n    onCreate({\n      name: taskName,\n      description: taskDesc,\n    });\n\n    setTaskName('');\n    setTaskDesc('');\n    onClose();\n  };\n\n  return (\n    <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n      <div className=\"absolute inset-0 bg-black/80 backdrop-blur-sm\" onClick={onClose} />\n      <div ref={modalRef} className=\"relative w-full max-w-lg glass-strong rounded-2xl border border-white/10 p-6\">\n        <div className=\"flex items-center justify-between mb-6\">\n          <h2 className=\"text-2xl font-bold text-white\">创建新任务</h2>\n          <button onClick={onClose} className=\"p-2 rounded-lg hover:bg-white/5 transition-colors\">\n            <X className=\"w-5 h-5 text-gray-400\" />\n          </button>\n        </div>\n\n        <form onSubmit={handleSubmit} className=\"space-y-6\">\n          {/* Agent indicator */}\n          <div className=\"flex items-center gap-3 p-4 rounded-xl bg-white/5 border border-white/10\">\n            <div className=\"w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center\">\n              <Globe className=\"w-5 h-5 text-white\" />\n            </div>\n            <div>\n              <div className=\"text-white font-medium\">Web Research Agent</div>\n              <div className=\"text-xs text-gray-500\">网页信息收集与分析</div>\n            </div>\n          </div>\n\n          {/* Task Details */}\n          <div className=\"space-y-4\">\n            <div>\n              <label className=\"block text-sm text-gray-400 mb-2\">任务名称</label>\n              <Input\n                value={taskName}\n                onChange={(e) => setTaskName(e.target.value)}\n                placeholder=\"例如：总结 Hacker News AI 新闻\"\n                className=\"bg-white/5 border-white/10 text-white placeholder:text-gray-600 rounded-xl\"\n              />\n            </div>\n            <div>\n              <label className=\"block text-sm text-gray-400 mb-2\">任务描述</label>\n              <Textarea\n                value={taskDesc}\n                onChange={(e) => setTaskDesc(e.target.value)}\n                placeholder=\"描述您希望 Agent 完成的研究任务...\"\n                className=\"bg-white/5 border-white/10 text-white placeholder:text-gray-600 rounded-xl min-h-[100px]\"\n              />\n            </div>\n          </div>\n\n          {/* Actions */}\n          <div className=\"flex gap-3\">\n            <Button type=\"button\" variant=\"outline\" onClick={onClose} className=\"flex-1 border-white/10 text-white hover:bg-white/5\">\n              取消\n            </Button>\n            <Button\n              type=\"submit\"\n              disabled={!taskName}\n              className=\"flex-1 bg-purple-600 hover:bg-purple-700 text-white disabled:opacity-50\"\n            >\n              <Play className=\"w-4 h-4 mr-2\" />\n              开始任务\n            </Button>\n          </div>\n        </form>\n      </div>\n    </div>\n  );\n};\n\n// Task Card Component\nconst TaskCard = ({\n  task,\n  onClick,\n}: {\n  task: Task;\n  onClick: () => void;\n}) => {\n  const statusColors = {\n    running: 'text-blue-400 bg-blue-500/10 border-blue-500/30',\n    completed: 'text-green-400 bg-green-500/10 border-green-500/30',\n    paused: 'text-yellow-400 bg-yellow-500/10 border-yellow-500/30',\n    failed: 'text-red-400 bg-red-500/10 border-red-500/30',\n  };\n\n  const statusIcons = {\n    running: Loader2,\n    completed: CheckCircle,\n    paused: Clock,\n    failed: AlertCircle,\n  };\n\n  const statusLabels = {\n    running: '运行中',\n    completed: '已完成',\n    paused: '已暂停',\n    failed: '失败',\n  };\n\n  const StatusIcon = statusIcons[task.status];\n\n  return (\n    <div\n      onClick={onClick}\n      className=\"p-5 rounded-xl glass border border-white/5 hover:border-purple-500/30 transition-all duration-300 cursor-pointer group\"\n    >\n      <div className=\"flex items-start justify-between mb-4\">\n        <div className=\"flex items-center gap-3\">\n          <div className={`p-2 rounded-lg ${statusColors[task.status]}`}>\n            <StatusIcon className={`w-4 h-4 ${task.status === 'running' ? 'animate-spin' : ''}`} />\n          </div>\n          <div>\n            <h3 className=\"text-white font-medium group-hover:text-purple-400 transition-colors\">{task.name}</h3>\n            <p className=\"text-sm text-gray-500\">{statusLabels[task.status]}</p>\n          </div>\n        </div>\n      </div>\n\n      <p className=\"text-gray-400 text-sm mb-4 line-clamp-2\">{task.description}</p>\n\n      {/* Progress */}\n      <div className=\"space-y-2\">\n        <div className=\"flex items-center justify-between text-xs\">\n          <span className=\"text-gray-500\">进度</span>\n          <span className=\"text-white\">{task.progress}%</span>\n        </div>\n        <div className=\"h-2 rounded-full bg-white/10 overflow-hidden\">\n          <div\n            className={`h-full rounded-full transition-all duration-500 ${\n              task.status === 'completed'\n                ? 'bg-gradient-to-r from-green-500 to-emerald-500'\n                : 'bg-gradient-to-r from-purple-500 to-pink-500'\n            }`}\n            style={{ width: `${task.progress}%` }}\n          />\n        </div>\n      </div>\n\n      <div className=\"mt-4 flex items-center justify-between text-xs text-gray-500\">\n        <span>创建于 {task.createdAt}</span>\n        <span>{task.logs.length} 条日志</span>\n      </div>\n    </div>\n  );\n};\n\n// Task Detail Panel\nconst TaskDetailPanel = ({\n  task,\n  onClose,\n  tasks,\n  onSendMessage,\n}: {\n  task: Task | null;\n  onClose: () => void;\n  tasks: Task[];\n  onSendMessage: (taskId: string, message: string) => void;\n}) => {\n  const panelRef = useRef<HTMLDivElement>(null);\n  const [message, setMessage] = useState('');\n  const logsEndRef = useRef<HTMLDivElement>(null);\n\n  const liveTask = task ? tasks.find((t) => t.id === task.id) || task : null;\n\n  useEffect(() => {\n    if (liveTask && panelRef.current) {\n      gsap.fromTo(\n        panelRef.current,\n        { x: '100%' },\n        { x: 0, duration: 0.5, ease: 'expo.out' }\n      );\n    }\n  }, [liveTask?.id]);\n\n  useEffect(() => {\n    logsEndRef.current?.scrollIntoView({ behavior: 'smooth' });\n  }, [liveTask?.logs.length]);\n\n  if (!liveTask) return null;\n\n  const handleSend = () => {\n    if (!message.trim()) return;\n    onSendMessage(liveTask.id, message);\n    setMessage('');\n  };\n\n  return (\n    <div\n      ref={panelRef}\n      className=\"fixed right-0 top-0 h-full w-full max-w-md glass-strong border-l border-white/5 z-40 overflow-hidden\"\n      style={{ transform: 'translateX(100%)' }}\n    >\n      {/* Header */}\n      <div className=\"h-16 border-b border-white/5 flex items-center justify-between px-6\">\n        <h3 className=\"text-lg font-semibold text-white\">任务详情</h3>\n        <button onClick={onClose} className=\"p-2 rounded-lg hover:bg-white/5 transition-colors\">\n          <X className=\"w-5 h-5 text-gray-400\" />\n        </button>\n      </div>\n\n      {/* Content */}\n      <div className=\"h-[calc(100%-8rem)] overflow-y-auto p-6 space-y-6\">\n        {/* Task Info */}\n        <div>\n          <h2 className=\"text-xl font-bold text-white mb-2\">{liveTask.name}</h2>\n          <p className=\"text-gray-400\">{liveTask.description}</p>\n        </div>\n\n        {/* Status & Progress */}\n        <div className=\"p-4 rounded-xl bg-white/5\">\n          <div className=\"flex items-center justify-between mb-3\">\n            <div className={`flex items-center gap-2 ${\n              liveTask.status === 'running' ? 'text-blue-400' :\n              liveTask.status === 'completed' ? 'text-green-400' :\n              liveTask.status === 'paused' ? 'text-yellow-400' : 'text-red-400'\n            }`}>\n              {liveTask.status === 'running' && <Loader2 className=\"w-4 h-4 animate-spin\" />}\n              {liveTask.status === 'completed' && <CheckCircle className=\"w-4 h-4\" />}\n              {liveTask.status === 'paused' && <Clock className=\"w-4 h-4\" />}\n              {liveTask.status === 'failed' && <AlertCircle className=\"w-4 h-4\" />}\n              <span className=\"font-medium\">\n                {liveTask.status === 'running' ? '运行中' :\n                 liveTask.status === 'completed' ? '已完成' :\n                 liveTask.status === 'paused' ? '已暂停' : '失败'}\n              </span>\n            </div>\n            <span className=\"text-white font-medium\">{Math.round(liveTask.progress)}%</span>\n          </div>\n          <div className=\"h-2 rounded-full bg-white/10 overflow-hidden\">\n            <div\n              className=\"h-full rounded-full bg-gradient-to-r from-purple-500 to-pink-500 transition-all duration-500\"\n              style={{ width: `${liveTask.progress}%` }}\n            />\n          </div>\n        </div>\n\n        {/* Logs */}\n        <div>\n          <h4 className=\"text-sm font-medium text-white mb-3 flex items-center gap-2\">\n            <Terminal className=\"w-4 h-4\" />\n            执行日志\n          </h4>\n          <div className=\"space-y-2\">\n            {liveTask.logs.map((log, i) => (\n              <div key={i} className=\"flex items-start gap-3 p-3 rounded-lg bg-white/5\">\n                <span className=\"text-xs text-gray-500 mt-0.5\">{i + 1}</span>\n                <span className=\"text-sm text-gray-300 whitespace-pre-wrap break-words\">{log}</span>\n              </div>\n            ))}\n            <div ref={logsEndRef} />\n          </div>\n        </div>\n      </div>\n\n      {/* Chat Input */}\n      <div className=\"h-16 border-t border-white/5 p-4\">\n        <div className=\"flex gap-2\">\n          <Input\n            value={message}\n            onChange={(e) => setMessage(e.target.value)}\n            onKeyDown={(e) => e.key === 'Enter' && handleSend()}\n            placeholder=\"向 Agent 发送追加指令...\"\n            className=\"flex-1 bg-white/5 border-white/10 text-white placeholder:text-gray-600 rounded-xl\"\n          />\n          <Button size=\"icon\" onClick={handleSend} className=\"bg-purple-600 hover:bg-purple-700 rounded-xl\">\n            <Send className=\"w-4 h-4\" />\n          </Button>\n        </div>\n      </div>\n    </div>\n  );\n};\n\n// Tasks View\nconst TasksView = ({\n  tasks,\n  onTaskClick,\n  onNewTask,\n}: {\n  tasks: Task[];\n  onTaskClick: (task: Task) => void;\n  onNewTask: () => void;\n}) => {\n  const [filter, setFilter] = useState<'all' | 'running' | 'completed'>('all');\n\n  const filteredTasks = tasks.filter((task) => {\n    if (filter === 'all') return true;\n    return task.status === filter;\n  });\n\n  return (\n    <div className=\"p-6\">\n      {/* Actions Bar */}\n      <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8\">\n        <div>\n          <h1 className=\"text-2xl font-bold text-white mb-1\">任务中心</h1>\n          <p className=\"text-gray-500\">管理和监控您的 Web Research 任务</p>\n        </div>\n        <Button onClick={onNewTask} className=\"bg-purple-600 hover:bg-purple-700 text-white rounded-xl\">\n          <Plus className=\"w-4 h-4 mr-2\" />\n          新建任务\n        </Button>\n      </div>\n\n      {/* Stats */}\n      <div className=\"grid grid-cols-3 gap-4 mb-8\">\n        {[\n          { label: '总任务', value: tasks.length, color: 'from-purple-500 to-pink-500' },\n          { label: '运行中', value: tasks.filter((t) => t.status === 'running').length, color: 'from-blue-500 to-cyan-500' },\n          { label: '已完成', value: tasks.filter((t) => t.status === 'completed').length, color: 'from-green-500 to-emerald-500' },\n        ].map((stat, i) => (\n          <div key={i} className=\"p-4 rounded-xl glass border border-white/5\">\n            <div className={`text-2xl font-bold bg-gradient-to-r ${stat.color} bg-clip-text text-transparent`}>\n              {stat.value}\n            </div>\n            <div className=\"text-sm text-gray-500\">{stat.label}</div>\n          </div>\n        ))}\n      </div>\n\n      {/* Filter Tabs */}\n      <div className=\"flex items-center gap-2 mb-6\">\n        {[\n          { id: 'all', label: '全部' },\n          { id: 'running', label: '运行中' },\n          { id: 'completed', label: '已完成' },\n        ].map((tab) => (\n          <button\n            key={tab.id}\n            onClick={() => setFilter(tab.id as any)}\n            className={`px-4 py-2 rounded-lg text-sm transition-all duration-300 ${\n              filter === tab.id\n                ? 'bg-purple-600 text-white'\n                : 'text-gray-400 hover:bg-white/5 hover:text-white'\n            }`}\n          >\n            {tab.label}\n          </button>\n        ))}\n      </div>\n\n      {/* Tasks Grid */}\n      <div className=\"grid md:grid-cols-2 lg:grid-cols-3 gap-4\">\n        {filteredTasks.map((task) => (\n          <TaskCard key={task.id} task={task} onClick={() => onTaskClick(task)} />\n        ))}\n      </div>\n\n      {filteredTasks.length === 0 && (\n        <div className=\"text-center py-20\">\n          <div className=\"w-20 h-20 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-4\">\n            <Terminal className=\"w-8 h-8 text-gray-500\" />\n          </div>\n          <h3 className=\"text-white font-medium mb-2\">暂无任务</h3>\n          <p className=\"text-gray-500 mb-4\">创建您的第一个 Web Research 任务</p>\n          <Button onClick={onNewTask} variant=\"outline\" className=\"border-white/10 text-white hover:bg-white/5\">\n            <Plus className=\"w-4 h-4 mr-2\" />\n            新建任务\n          </Button>\n        </div>\n      )}\n    </div>\n  );\n};\n\n// Main Dashboard Component\nconst Dashboard = () => {\n  const [tasks, setTasks] = useState<Task[]>([]);\n  const [selectedTask, setSelectedTask] = useState<Task | null>(null);\n  const [isNewTaskModalOpen, setIsNewTaskModalOpen] = useState(false);\n  const [taskWsMap] = useState<Map<string, WebSocket>>(new Map());\n  const navigate = useNavigate();\n  const username = getUsername();\n\n  useEffect(() => {\n    if (!localStorage.getItem('token')) navigate('/login');\n  }, [navigate]);\n\n  const connectTask = (task: Task) => {\n    const token = localStorage.getItem('token');\n    const ws = new WebSocket(`${WS_BASE}/ws?token=${token}&task=${task.id}`);\n\n    taskWsMap.set(task.id, ws);\n\n    ws.onopen = () => {\n      ws.send(JSON.stringify({ type: 'task', content: task.description, task_id: task.id }));\n    };\n\n    ws.onmessage = (e) => {\n      const msg = JSON.parse(e.data);\n      setTasks((prev) =>\n        prev.map((t) => {\n          if (t.id !== task.id) return t;\n          switch (msg.type) {\n            case 'status':\n              return { ...t, logs: [...t.logs, msg.message], progress: Math.min(t.progress + 15, 90) };\n            case 'reasoning':\n              return { ...t, logs: [...t.logs, `🧠 ${msg.content}`] };\n            case 'thinking':\n              return { ...t, logs: [...t.logs, `💭 ${msg.content}`] };\n            case 'action':\n              return { ...t, logs: [...t.logs, `🔧 ${msg.tool}: ${JSON.stringify(msg.args)}`] };\n            case 'screenshot':\n              return { ...t, screenshots: [...t.screenshots, msg.url], logs: [...t.logs, `📸 截图: ${msg.url}`] };\n            case 'answer':\n              return { ...t, status: 'completed' as const, progress: 100, logs: [...t.logs, `✅ ${msg.content}`] };\n            case 'error':\n              return { ...t, status: 'failed' as const, logs: [...t.logs, `❌ ${msg.message}`] };\n            default:\n              return t;\n          }\n        })\n      );\n    };\n\n    ws.onerror = () => {\n      setTasks((prev) => prev.map((t) => t.id === task.id ? { ...t, status: 'failed' as const, logs: [...t.logs, '❌ 连接错误'] } : t));\n    };\n\n    return ws;\n  };\n\n  const handleCreateTask = (taskData: Partial<Task>) => {\n    const newTask: Task = {\n      id: crypto.randomUUID(),\n      name: taskData.name || '',\n      description: taskData.description || '',\n      status: 'running',\n      progress: 5,\n      createdAt: '刚刚',\n      logs: ['任务已创建，正在连接...'],\n      screenshots: [],\n    };\n    setTasks((prev) => [newTask, ...prev]);\n    connectTask(newTask);\n  };\n\n  const handleSendMessage = (taskId: string, message: string) => {\n    const ws = taskWsMap.get(taskId);\n    if (ws && ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify({ type: 'task', content: message, task_id: taskId }));\n      setTasks((prev) =>\n        prev.map((t) =>\n          t.id === taskId\n            ? { ...t, logs: [...t.logs, `📤 ${message}`], status: 'running' as const }\n            : t\n        )\n      );\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen bg-black\">\n      <div className=\"noise-overlay\" />\n\n      <Sidebar username={username} />\n\n      <div className=\"ml-64\">\n        <main className=\"min-h-screen\">\n          <TasksView\n            tasks={tasks}\n            onTaskClick={setSelectedTask}\n            onNewTask={() => setIsNewTaskModalOpen(true)}\n          />\n        </main>\n      </div>\n\n      <NewTaskModal\n        isOpen={isNewTaskModalOpen}\n        onClose={() => setIsNewTaskModalOpen(false)}\n        onCreate={handleCreateTask}\n      />\n\n      <TaskDetailPanel\n        task={selectedTask}\n        onClose={() => setSelectedTask(null)}\n        tasks={tasks}\n        onSendMessage={handleSendMessage}\n      />\n    </div>\n  );\n};\n\nexport default Dashboard;\n\n=== Operation 2 Result (Text) ===\nexport const API_BASE = \"https://api.agents.cloudc.top\";\nexport const WS_BASE = \"wss://api.agents.cloudc.top\";"
                  }
                ],
                "status": "Success"
              }
            ]
          }
        },
        "timestamp": null,
        "images": null
      },
      "assistant": {
        "ToolUse": {
          "message_id": "cae7a698-f91e-4ab0-bbca-405cde729cff",
          "content": "现在改 Dashboard，加历史任务加载、删除、以及新的结构化日志类型（plan/step_start/step_done/observation）：",
          "tool_uses": [
            {
              "id": "tooluse_4VBy0BXP6XRWAsid4PdvBG",
              "name": "fs_write",
              "orig_name": "fs_write",
              "args": {
                "command": "create",
                "file_text": "import { useState, useEffect, useRef } from 'react';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Textarea } from '@/components/ui/textarea';\nimport {\n  Zap, Plus, LogOut, Play, CheckCircle, Clock, AlertCircle,\n  Terminal, Globe, X, Send, Loader2, Trash2,\n} from 'lucide-react';\nimport { Link, useNavigate } from 'react-router-dom';\nimport gsap from 'gsap';\nimport { API_BASE, WS_BASE } from '@/lib/api';\n\ninterface Task {\n  id: string;\n  name: string;\n  description: string;\n  status: 'running' | 'completed' | 'failed';\n  progress: number;\n  createdAt: string;\n  logs: string[];\n  screenshots: string[];\n  plan?: { id: number; description: string; status: string }[];\n}\n\nfunction getToken() { return localStorage.getItem('token') || ''; }\nfunction getUsername(): string {\n  try { const [, u] = atob(getToken()).split(':'); return u || 'User'; } catch { return 'User'; }\n}\n\n// --- API helpers ---\nasync function fetchTasks(): Promise<any[]> {\n  const res = await fetch(`${API_BASE}/api/tasks?token=${getToken()}`);\n  if (!res.ok) return [];\n  const data = await res.json();\n  return data.tasks || [];\n}\n\nasync function deleteTask(id: string) {\n  await fetch(`${API_BASE}/api/tasks/${id}?token=${getToken()}`, { method: 'DELETE' });\n}\n\n// --- Sidebar ---\nconst Sidebar = ({ username }: { username: string }) => (\n  <div className=\"w-64 h-screen glass-strong border-r border-white/5 flex flex-col fixed left-0 top-0\">\n    <div className=\"p-6 border-b border-white/5\">\n      <Link to=\"/\" className=\"flex items-center gap-3\">\n        <div className=\"w-10 h-10 rounded-xl bg-gradient-to-br from-purple-600 to-pink-600 flex items-center justify-center\">\n          <Zap className=\"w-5 h-5 text-white\" />\n        </div>\n        <span className=\"text-xl font-bold text-white\">Agents</span>\n      </Link>\n    </div>\n    <nav className=\"flex-1 p-4 space-y-2\">\n      <div className=\"w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-purple-600/20 text-purple-400 border border-purple-500/30\">\n        <Terminal className=\"w-5 h-5\" /><span>任务中心</span>\n      </div>\n    </nav>\n    <div className=\"p-4 border-t border-white/5\">\n      <div className=\"flex items-center gap-3 p-3 rounded-xl bg-white/5\">\n        <div className=\"w-10 h-10 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-semibold\">\n          {username.charAt(0).toUpperCase()}\n        </div>\n        <div className=\"flex-1 min-w-0\"><div className=\"text-white font-medium truncate\">{username}</div></div>\n        <Link to=\"/\"><LogOut className=\"w-5 h-5 text-gray-400 hover:text-white cursor-pointer\" /></Link>\n      </div>\n    </div>\n  </div>\n);\n\n// --- New Task Modal ---\nconst NewTaskModal = ({ isOpen, onClose, onCreate }: {\n  isOpen: boolean; onClose: () => void; onCreate: (t: Partial<Task>) => void;\n}) => {\n  const [name, setName] = useState('');\n  const [desc, setDesc] = useState('');\n  const ref = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    if (isOpen && ref.current) gsap.fromTo(ref.current, { opacity: 0, scale: 0.95 }, { opacity: 1, scale: 1, duration: 0.3, ease: 'expo.out' });\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  const submit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!name) return;\n    onCreate({ name, description: desc });\n    setName(''); setDesc(''); onClose();\n  };\n\n  return (\n    <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n      <div className=\"absolute inset-0 bg-black/80 backdrop-blur-sm\" onClick={onClose} />\n      <div ref={ref} className=\"relative w-full max-w-lg glass-strong rounded-2xl border border-white/10 p-6\">\n        <div className=\"flex items-center justify-between mb-6\">\n          <h2 className=\"text-2xl font-bold text-white\">创建新任务</h2>\n          <button onClick={onClose} className=\"p-2 rounded-lg hover:bg-white/5\"><X className=\"w-5 h-5 text-gray-400\" /></button>\n        </div>\n        <form onSubmit={submit} className=\"space-y-6\">\n          <div className=\"flex items-center gap-3 p-4 rounded-xl bg-white/5 border border-white/10\">\n            <div className=\"w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center\">\n              <Globe className=\"w-5 h-5 text-white\" />\n            </div>\n            <div><div className=\"text-white font-medium\">Web Research Agent</div><div className=\"text-xs text-gray-500\">网页信息收集与分析</div></div>\n          </div>\n          <div className=\"space-y-4\">\n            <div>\n              <label className=\"block text-sm text-gray-400 mb-2\">任务名称</label>\n              <Input value={name} onChange={e => setName(e.target.value)} placeholder=\"例如：总结 HN AI 新闻\" className=\"bg-white/5 border-white/10 text-white placeholder:text-gray-600 rounded-xl\" />\n            </div>\n            <div>\n              <label className=\"block text-sm text-gray-400 mb-2\">任务描述</label>\n              <Textarea value={desc} onChange={e => setDesc(e.target.value)} placeholder=\"描述您希望 Agent 完成的研究任务...\" className=\"bg-white/5 border-white/10 text-white placeholder:text-gray-600 rounded-xl min-h-[100px]\" />\n            </div>\n          </div>\n          <div className=\"flex gap-3\">\n            <Button type=\"button\" variant=\"outline\" onClick={onClose} className=\"flex-1 border-white/10 text-white hover:bg-white/5\">取消</Button>\n            <Button type=\"submit\" disabled={!name} className=\"flex-1 bg-purple-600 hover:bg-purple-700 text-white disabled:opacity-50\"><Play className=\"w-4 h-4 mr-2\" />开始任务</Button>\n          </div>\n        </form>\n      </div>\n    </div>\n  );\n};\n\n// --- Task Card ---\nconst TaskCard = ({ task, onClick, onDelete }: { task: Task; onClick: () => void; onDelete: () => void }) => {\n  const colors: Record<string, string> = {\n    running: 'text-blue-400 bg-blue-500/10 border-blue-500/30',\n    completed: 'text-green-400 bg-green-500/10 border-green-500/30',\n    failed: 'text-red-400 bg-red-500/10 border-red-500/30',\n  };\n  const icons: Record<string, any> = { running: Loader2, completed: CheckCircle, failed: AlertCircle };\n  const labels: Record<string, string> = { running: '运行中', completed: '已完成', failed: '失败' };\n  const Icon = icons[task.status] || Clock;\n\n  return (\n    <div className=\"p-5 rounded-xl glass border border-white/5 hover:border-purple-500/30 transition-all duration-300 cursor-pointer group relative\">\n      <button onClick={e => { e.stopPropagation(); onDelete(); }}\n        className=\"absolute top-3 right-3 p-1.5 rounded-lg opacity-0 group-hover:opacity-100 hover:bg-red-500/20 transition-all\">\n        <Trash2 className=\"w-4 h-4 text-red-400\" />\n      </button>\n      <div onClick={onClick}>\n        <div className=\"flex items-center gap-3 mb-3\">\n          <div className={`p-2 rounded-lg ${colors[task.status] || ''}`}>\n            <Icon className={`w-4 h-4 ${task.status === 'running' ? 'animate-spin' : ''}`} />\n          </div>\n          <div>\n            <h3 className=\"text-white font-medium group-hover:text-purple-400 transition-colors\">{task.name}</h3>\n            <p className=\"text-xs text-gray-500\">{labels[task.status]}</p>\n          </div>\n        </div>\n        <p className=\"text-gray-400 text-sm mb-3 line-clamp-2\">{task.description}</p>\n        <div className=\"flex items-center justify-between text-xs text-gray-500\">\n          <span>{task.createdAt}</span>\n          <span>{task.logs.length} 条日志</span>\n        </div>\n      </div>\n    </div>\n  );\n};\n\n// --- Task Detail Panel ---\nconst TaskDetailPanel = ({ task, onClose, tasks, onSendMessage }: {\n  task: Task | null; onClose: () => void; tasks: Task[]; onSendMessage: (id: string, msg: string) => void;\n}) => {\n  const ref = useRef<HTMLDivElement>(null);\n  const [message, setMessage] = useState('');\n  const logsEnd = useRef<HTMLDivElement>(null);\n  const live = task ? tasks.find(t => t.id === task.id) || task : null;\n\n  useEffect(() => {\n    if (live && ref.current) gsap.fromTo(ref.current, { x: '100%' }, { x: 0, duration: 0.5, ease: 'expo.out' });\n  }, [live?.id]);\n\n  useEffect(() => { logsEnd.current?.scrollIntoView({ behavior: 'smooth' }); }, [live?.logs.length]);\n\n  if (!live) return null;\n\n  const send = () => { if (!message.trim()) return; onSendMessage(live.id, message); setMessage(''); };\n\n  return (\n    <div ref={ref} className=\"fixed right-0 top-0 h-full w-full max-w-md glass-strong border-l border-white/5 z-40 overflow-hidden\" style={{ transform: 'translateX(100%)' }}>\n      <div className=\"h-16 border-b border-white/5 flex items-center justify-between px-6\">\n        <h3 className=\"text-lg font-semibold text-white\">任务详情</h3>\n        <button onClick={onClose} className=\"p-2 rounded-lg hover:bg-white/5\"><X className=\"w-5 h-5 text-gray-400\" /></button>\n      </div>\n      <div className=\"h-[calc(100%-8rem)] overflow-y-auto p-6 space-y-6\">\n        <div>\n          <h2 className=\"text-xl font-bold text-white mb-2\">{live.name}</h2>\n          <p className=\"text-gray-400\">{live.description}</p>\n        </div>\n\n        {/* Plan Steps */}\n        {live.plan && live.plan.length > 0 && (\n          <div className=\"p-4 rounded-xl bg-white/5 space-y-2\">\n            <h4 className=\"text-sm font-medium text-purple-400 mb-2\">📋 执行计划</h4>\n            {live.plan.map(s => (\n              <div key={s.id} className=\"flex items-center gap-2 text-sm\">\n                <span>{s.status === 'done' ? '✅' : s.status === 'running' ? '▶️' : s.status === 'failed' ? '❌' : '⬜'}</span>\n                <span className={s.status === 'done' ? 'text-green-400' : s.status === 'running' ? 'text-blue-400' : 'text-gray-400'}>\n                  {s.id}. {s.description}\n                </span>\n              </div>\n            ))}\n          </div>\n        )}\n\n        {/* Status */}\n        <div className=\"p-4 rounded-xl bg-white/5\">\n          <div className=\"flex items-center gap-2\">\n            {live.status === 'running' && <Loader2 className=\"w-4 h-4 animate-spin text-blue-400\" />}\n            {live.status === 'completed' && <CheckCircle className=\"w-4 h-4 text-green-400\" />}\n            {live.status === 'failed' && <AlertCircle className=\"w-4 h-4 text-red-400\" />}\n            <span className={live.status === 'running' ? 'text-blue-400' : live.status === 'completed' ? 'text-green-400' : 'text-red-400'}>\n              {live.status === 'running' ? '运行中' : live.status === 'completed' ? '已完成' : '失败'}\n            </span>\n            <span className=\"ml-auto text-white font-medium\">{Math.round(live.progress)}%</span>\n          </div>\n          <div className=\"h-2 rounded-full bg-white/10 overflow-hidden mt-2\">\n            <div className=\"h-full rounded-full bg-gradient-to-r from-purple-500 to-pink-500 transition-all duration-500\" style={{ width: `${live.progress}%` }} />\n          </div>\n        </div>\n\n        {/* Logs */}\n        <div>\n          <h4 className=\"text-sm font-medium text-white mb-3 flex items-center gap-2\"><Terminal className=\"w-4 h-4\" />执行日志</h4>\n          <div className=\"space-y-2\">\n            {live.logs.map((log, i) => (\n              <div key={i} className=\"flex items-start gap-3 p-3 rounded-lg bg-white/5\">\n                <span className=\"text-xs text-gray-500 mt-0.5\">{i + 1}</span>\n                <span className=\"text-sm text-gray-300 whitespace-pre-wrap break-words\">{log}</span>\n              </div>\n            ))}\n            <div ref={logsEnd} />\n          </div>\n        </div>\n      </div>\n      <div className=\"h-16 border-t border-white/5 p-4\">\n        <div className=\"flex gap-2\">\n          <Input value={message} onChange={e => setMessage(e.target.value)} onKeyDown={e => e.key === 'Enter' && send()}\n            placeholder=\"向 Agent 发送追加指令...\" className=\"flex-1 bg-white/5 border-white/10 text-white placeholder:text-gray-600 rounded-xl\" />\n          <Button size=\"icon\" onClick={send} className=\"bg-purple-600 hover:bg-purple-700 rounded-xl\"><Send className=\"w-4 h-4\" /></Button>\n        </div>\n      </div>\n    </div>\n  );\n};\n\n// --- Main Dashboard ---\nconst Dashboard = () => {\n  const [tasks, setTasks] = useState<Task[]>([]);\n  const [selectedTask, setSelectedTask] = useState<Task | null>(null);\n  const [isNewTaskModalOpen, setIsNewTaskModalOpen] = useState(false);\n  const [taskWsMap] = useState<Map<string, WebSocket>>(new Map());\n  const [filter, setFilter] = useState<'all' | 'running' | 'completed'>('all');\n  const navigate = useNavigate();\n  const username = getUsername();\n\n  useEffect(() => {\n    if (!getToken()) { navigate('/login'); return; }\n    // Load history tasks from D1\n    fetchTasks().then(rows => {\n      const history: Task[] = rows.map((r: any) => ({\n        id: r.id, name: r.title || r.id, description: '', status: r.status || 'completed',\n        progress: r.status === 'completed' ? 100 : r.status === 'failed' ? 100 : 0,\n        createdAt: r.created_at || '', logs: [], screenshots: [],\n      }));\n      setTasks(prev => {\n        // Merge: keep live tasks, add history ones that aren't already present\n        const liveIds = new Set(prev.map(t => t.id));\n        return [...prev, ...history.filter(h => !liveIds.has(h.id))];\n      });\n    });\n  }, [navigate]);\n\n  const connectTask = (task: Task) => {\n    const ws = new WebSocket(`${WS_BASE}/ws?token=${getToken()}&task=${task.id}&title=${encodeURIComponent(task.name)}`);\n    taskWsMap.set(task.id, ws);\n\n    ws.onopen = () => {\n      ws.send(JSON.stringify({ type: 'task', content: task.description, task_id: task.id }));\n    };\n\n    ws.onmessage = (e) => {\n      const msg = JSON.parse(e.data);\n      setTasks(prev => prev.map(t => {\n        if (t.id !== task.id) return t;\n        switch (msg.type) {\n          case 'plan':\n            return { ...t, plan: msg.steps, logs: [...t.logs, `📋 计划: ${msg.steps?.map((s: any) => `${s.id}. ${s.description}`).join(' → ')}`] };\n          case 'step_start':\n            return { ...t, plan: t.plan?.map(s => s.id === msg.step_id ? { ...s, status: 'running' } : s),\n              logs: [...t.logs, `▶️ 开始: ${msg.description || `步骤 ${msg.step_id}`}`], progress: Math.min(t.progress + 10, 90) };\n          case 'step_done':\n            return { ...t, plan: t.plan?.map(s => s.id === msg.step_id ? { ...s, status: 'done' } : s),\n              logs: [...t.logs, `✅ 完成: 步骤 ${msg.step_id}`] };\n          case 'observation':\n            return { ...t, logs: [...t.logs, `📄 ${msg.summary}`] };\n          case 'status':\n            return { ...t, logs: [...t.logs, msg.message], progress: Math.min(t.progress + 5, 90) };\n          case 'reasoning':\n            return { ...t, logs: [...t.logs, `🧠 ${msg.content}`] };\n          case 'thinking':\n            return { ...t, logs: [...t.logs, `💭 ${msg.content}`] };\n          case 'action':\n            return { ...t, logs: [...t.logs, `🔧 ${msg.tool}: ${JSON.stringify(msg.args)}`] };\n          case 'screenshot':\n            return { ...t, screenshots: [...t.screenshots, msg.url], logs: [...t.logs, `📸 截图: ${msg.url}`] };\n          case 'answer':\n            return { ...t, status: 'completed', progress: 100, logs: [...t.logs, `✅ ${msg.content}`] };\n          case 'error':\n            return { ...t, status: 'failed', progress: 100, logs: [...t.logs, `❌ ${msg.message}`] };\n          default: return t;\n        }\n      }));\n    };\n\n    ws.onerror = () => {\n      setTasks(prev => prev.map(t => t.id === task.id ? { ...t, status: 'failed', logs: [...t.logs, '❌ 连接错误'] } : t));\n    };\n  };\n\n  const handleCreate = (data: Partial<Task>) => {\n    const t: Task = {\n      id: crypto.randomUUID(), name: data.name || '', description: data.description || '',\n      status: 'running', progress: 5, createdAt: '刚刚', logs: ['任务已创建，正在连接...'], screenshots: [],\n    };\n    setTasks(prev => [t, ...prev]);\n    connectTask(t);\n  };\n\n  const handleDelete = async (id: string) => {\n    await deleteTask(id);\n    setTasks(prev => prev.filter(t => t.id !== id));\n    if (selectedTask?.id === id) setSelectedTask(null);\n    const ws = taskWsMap.get(id);\n    if (ws) { ws.close(); taskWsMap.delete(id); }\n  };\n\n  const handleSend = (taskId: string, message: string) => {\n    const ws = taskWsMap.get(taskId);\n    if (ws?.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify({ type: 'task', content: message, task_id: taskId }));\n      setTasks(prev => prev.map(t => t.id === taskId ? { ...t, logs: [...t.logs, `📤 ${message}`], status: 'running' } : t));\n    }\n  };\n\n  const filtered = tasks.filter(t => filter === 'all' || t.status === filter);\n\n  return (\n    <div className=\"min-h-screen bg-black\">\n      <div className=\"noise-overlay\" />\n      <Sidebar username={username} />\n      <div className=\"ml-64\">\n        <main className=\"min-h-screen p-6\">\n          {/* Header */}\n          <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8\">\n            <div>\n              <h1 className=\"text-2xl font-bold text-white mb-1\">任务中心</h1>\n              <p className=\"text-gray-500\">管理和监控您的 Web Research 任务</p>\n            </div>\n            <Button onClick={() => setIsNewTaskModalOpen(true)} className=\"bg-purple-600 hover:bg-purple-700 text-white rounded-xl\">\n              <Plus className=\"w-4 h-4 mr-2\" />新建任务\n            </Button>\n          </div>\n\n          {/* Stats */}\n          <div className=\"grid grid-cols-3 gap-4 mb-8\">\n            {[\n              { label: '总任务', value: tasks.length, color: 'from-purple-500 to-pink-500' },\n              { label: '运行中', value: tasks.filter(t => t.status === 'running').length, color: 'from-blue-500 to-cyan-500' },\n              { label: '已完成', value: tasks.filter(t => t.status === 'completed').length, color: 'from-green-500 to-emerald-500' },\n            ].map((s, i) => (\n              <div key={i} className=\"p-4 rounded-xl glass border border-white/5\">\n                <div className={`text-2xl font-bold bg-gradient-to-r ${s.color} bg-clip-text text-transparent`}>{s.value}</div>\n                <div className=\"text-sm text-gray-500\">{s.label}</div>\n              </div>\n            ))}\n          </div>\n\n          {/* Filter */}\n          <div className=\"flex items-center gap-2 mb-6\">\n            {(['all', 'running', 'completed'] as const).map(f => (\n              <button key={f} onClick={() => setFilter(f)}\n                className={`px-4 py-2 rounded-lg text-sm transition-all ${filter === f ? 'bg-purple-600 text-white' : 'text-gray-400 hover:bg-white/5'}`}>\n                {f === 'all' ? '全部' : f === 'running' ? '运行中' : '已完成'}\n              </button>\n            ))}\n          </div>\n\n          {/* Tasks Grid */}\n          <div className=\"grid md:grid-cols-2 lg:grid-cols-3 gap-4\">\n            {filtered.map(t => (\n              <TaskCard key={t.id} task={t} onClick={() => setSelectedTask(t)} onDelete={() => handleDelete(t.id)} />\n            ))}\n          </div>\n\n          {filtered.length === 0 && (\n            <div className=\"text-center py-20\">\n              <div className=\"w-20 h-20 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-4\">\n                <Terminal className=\"w-8 h-8 text-gray-500\" />\n              </div>\n              <h3 className=\"text-white font-medium mb-2\">暂无任务</h3>\n              <p className=\"text-gray-500 mb-4\">创建您的第一个 Web Research 任务</p>\n              <Button onClick={() => setIsNewTaskModalOpen(true)} variant=\"outline\" className=\"border-white/10 text-white hover:bg-white/5\">\n                <Plus className=\"w-4 h-4 mr-2\" />新建任务\n              </Button>\n            </div>\n          )}\n        </main>\n      </div>\n\n      <NewTaskModal isOpen={isNewTaskModalOpen} onClose={() => setIsNewTaskModalOpen(false)} onCreate={handleCreate} />\n      <TaskDetailPanel task={selectedTask} onClose={() => setSelectedTask(null)} tasks={tasks} onSendMessage={handleSend} />\n    </div>\n  );\n};\n\nexport default Dashboard;\n",
