                    "Text": "=== Operation 1 Result (Text) ===\nimport { DurableObject } from \"cloudflare:workers\";\nimport type { Env } from \"./index\";\n\n// Tool definition sent to LLM\nconst TOOLS = [\n  {\n    type: \"function\" as const,\n    function: {\n      name: \"navigate\",\n      description: \"Open a webpage and extract its text content and screenshot\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          url: { type: \"string\", description: \"The URL to visit\" },\n        },\n        required: [\"url\"],\n      },\n    },\n  },\n];\n\nconst SYSTEM_PROMPT = `You are a Web Research Agent. You help users research topics on the web.\n\nYou have a tool called \"navigate\" that opens a webpage and returns its text content.\n\nFor each task, follow this workflow:\n1. PLAN - First, outline your step-by-step plan to complete the task\n2. For each step:\n   - REASON - Explain why this step is needed\n   - ACT - Call the appropriate tool\n   - OBSERVE - Analyze the result and decide what to do next\n\nWhen you have enough information, provide your final summary directly without calling any tool.\nAlways think step by step and explain your reasoning.`;\n\ninterface ChatMessage {\n  role: \"system\" | \"user\" | \"assistant\" | \"tool\";\n  content: string | null;\n  tool_calls?: any[];\n  tool_call_id?: string;\n}\n\ninterface StepRecord {\n  index: number;\n  action: string;\n  input: any;\n  output: any;\n  screenshot_url?: string;\n}\n\nexport class AgentSession extends DurableObject<Env> {\n  private sessions: Set<WebSocket> = new Set();\n\n  async fetch(request: Request): Promise<Response> {\n    const upgradeHeader = request.headers.get(\"Upgrade\");\n    if (upgradeHeader !== \"websocket\") {\n      return new Response(\"Expected WebSocket\", { status: 426 });\n    }\n\n    const pair = new WebSocketPair();\n    const [client, server] = Object.values(pair);\n\n    this.ctx.acceptWebSocket(server);\n    this.sessions.add(server);\n\n    return new Response(null, { status: 101, webSocket: client });\n  }\n\n  async webSocketMessage(ws: WebSocket, message: string | ArrayBuffer) {\n    const data = JSON.parse(message as string);\n\n    if (data.type === \"task\") {\n      await this.runAgent(ws, data.content, data.task_id || crypto.randomUUID());\n    }\n  }\n\n  webSocketClose(ws: WebSocket) {\n    this.sessions.delete(ws);\n  }\n\n  private send(ws: WebSocket, type: string, payload: any) {\n    ws.send(JSON.stringify({ type, ...payload }));\n  }\n\n  private async runAgent(ws: WebSocket, userMessage: string, taskId: string) {\n    // Load or init conversation history\n    const messages: ChatMessage[] = (await this.ctx.storage.get(`task:${taskId}:messages`)) || [\n      { role: \"system\", content: SYSTEM_PROMPT },\n    ];\n    const steps: StepRecord[] = (await this.ctx.storage.get(`task:${taskId}:steps`)) || [];\n\n    messages.push({ role: \"user\", content: userMessage });\n\n    this.send(ws, \"status\", { message: \"Thinking...\" });\n\n    const MAX_STEPS = parseInt(this.env.MAX_STEPS || \"10\");\n\n    for (let i = 0; i < MAX_STEPS; i++) {\n      // Call LLM via AI Gateway\n      console.log(`[step ${i}] calling LLM, messages count: ${messages.length}`);\n      const llmResponse = await this.callLLM(messages);\n      console.log(`[step ${i}] LLM raw response:`, JSON.stringify(llmResponse).substring(0, 1000));\n\n      const choice = llmResponse.choices?.[0]?.message;\n      if (!choice) {\n        console.log(`[step ${i}] LLM returned empty choice`);\n        this.send(ws, \"error\", { message: \"LLM returned empty response\" });\n        return;\n      }\n\n      // If LLM wants to call a tool\n      if (choice.tool_calls && choice.tool_calls.length > 0) {\n        // Push reasoning to frontend\n        if (choice.reasoning_content) {\n          this.send(ws, \"reasoning\", { content: choice.reasoning_content });\n        }\n        if (choice.content) {\n          this.send