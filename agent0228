status\", { message: `Step ${steps.length} done, thinking...` });\n      } else {\n        // No tool call → final answer\n        messages.push({ role: \"assistant\", content: choice.content });\n        await this.ctx.storage.put(`task:${taskId}:messages`, messages);\n        await this.ctx.storage.put(`task:${taskId}:steps`, steps);\n\n        this.send(ws, \"answer\", { content: choice.content });\n        return;\n      }\n    }\n\n    this.send(ws, \"error\", { message: \"Max steps reached\" });\n  }\n\n  private async callLLM(messages: ChatMessage[]): Promise<any> {\n    const res = await fetch(`${this.env.AI_GATEWAY_BASE}/chat/completions`, {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${this.env.CF_AIG_TOKEN}`,\n      },\n      body: JSON.stringify({\n        model: this.env.AI_MODEL,\n        messages,\n        tools: TOOLS,\n      }),\n    });\n\n    if (!res.ok) {\n      const err = await res.text();\n      throw new Error(`LLM API error: ${res.status} ${err}`);\n    }\n\n    return res.json();\n  }\n\n  private async executeTool(name: string, args: any, taskId: string): Promise<any> {\n    if (name === \"navigate\") {\n      console.log(`[sandbox] calling ${this.env.SANDBOX_URL}/execute with url: ${args.url}`);\n      const res = await fetch(`${this.env.SANDBOX_URL}/execute`, {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ url: args.url, task_id: taskId }),\n      });\n\n      console.log(`[sandbox] response status: ${res.status}`);\n      if (!res.ok) {\n        const errText = await res.text();\n        console.log(`[sandbox] error body:`, errText);\n        return { text: `Error: sandbox returned ${res.status} - ${errText}`, metadata: {} };\n      }\n\n      return res.json();\n    }\n\n    return { text: `Unknown tool: ${name}`, metadata: {} };\n  }\n}\n\n=== Operation 2 Result (Text) ===\nimport 